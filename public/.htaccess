# Apache на reg.ru (Host-Lite). Файл попадает в dist/ при сборке и выкладывается в public_html.
# Назначение: HTTPS, без www, gzip-сжатие, агрессивный кеш для статики, SPA-friendly 404.

# ─── 1. Принудительный HTTPS + редирект www → без www ──────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTP → HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # www.* → без www (на обоих именах: punycode и кириллическом)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>

# ─── 2. Gzip-сжатие текстовых ресурсов ─────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ─── 3. Кеш-хедеры ──────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML и манифест — короткий кеш (часто обновляем)
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType application/manifest+json "access plus 1 day"

  # Статика с хешем в имени (Astro кладёт в /_astro/) — на год
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
  ExpiresByType video/mp4 "access plus 6 months"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# Astro-бандлы внутри /_astro/ хешируются по содержимому — можем смело immutable.
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2?|jpg|jpeg|png|webp|svg|ico|mp4)$">
    <If "%{REQUEST_URI} =~ m#^/_astro/#">
      Header set Cache-Control "public, max-age=31536000, immutable"
    </If>
  </FilesMatch>

  # Базовые security-хедеры
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# ─── 4. Кодировка по умолчанию ─────────────────────────────────────────────────
AddDefaultCharset UTF-8

# ─── 5. 404 → index.html отдаём НЕ нужно: сайт многостраничный (Astro SSG).
# Astro сам сгенерирует privacy/index.html, остальное → стандартная 404 от Astro
# (если был сгенерирован /404.html) или Apache.
ErrorDocument 404 /404.html
