---
import Base from '../layouts/Base.astro';
---

<Base title="Страница не найдена" description="Запрошенная страница не найдена. Вернитесь на главную, чтобы подобрать санаторий.">
  <main class="container-px grid min-h-[80vh] place-items-center py-20 text-center">
    <div>
      <p class="eyebrow justify-center">404</p>
      <h1 class="mt-4 font-display text-[clamp(2rem,1.5rem+2vw,3rem)] font-semibold">Страница не найдена</h1>
      <p class="mt-4 text-lead text-muted">Проверьте адрес или вернитесь на главную.</p>
      <a href="/" class="btn btn-primary btn-lg mt-8">На главную</a>
    </div>
  </main>
</Base>
