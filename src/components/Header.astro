---
import { Icon } from 'astro-icon/components';
// Фиксированная шапка. По умолчанию — прозрачная поверх hero-видео (светлый текст);
// при скролле получает класс .is-scrolled: подложка «лён» + backdrop-blur + тёмный текст.
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-colors duration-300">
  <div class="header-bar container-px flex h-20 items-center justify-between gap-4">
    <a href="#top" class="flex items-center gap-3 font-semibold">
      <span class="leaf-stone grid h-9 w-9 place-items-center rounded-[11px] text-ondark shadow-pine">
        <Icon name="lucide:leaf" class="h-5 w-5" />
      </span>
      <span class="font-display text-lg leading-none tracking-[-0.01em]">Санатории России</span>
    </a>
    <nav class="hidden items-center gap-1 md:flex">
      <a href="#advantages" class="nav-link">Преимущества</a>
      <a href="#catalog" class="nav-link">Санатории</a>
      <a href="#how" class="nav-link">Как это работает</a>
    </nav>
    <div class="flex items-center gap-2 sm:gap-3">
      <a href="tel:+70000000000" class="header-phone" aria-label="Позвонить: +7 (000) 000-00-00">
        <Icon name="lucide:phone" class="h-4 w-4 shrink-0" />
        <span class="hidden whitespace-nowrap lg:inline">+7 (000) 000-00-00</span>
      </a>
      <button type="button" data-lead-open data-lead-variant="full" class="btn btn-primary btn-sm">Оставить заявку</button>
    </div>
  </div>
</header>

<style>
  /* Зелёный «камень» под лист — из дизайн-системы */
  .leaf-stone {
    background: linear-gradient(150deg, var(--color-pine-600), var(--color-aqua-600));
  }

  /* Состояние по умолчанию — поверх тёмного hero-видео */
  #site-header {
    color: #fff;
  }
  .header-bar {
    transition: height 0.3s ease;
  }
  .nav-link {
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 7px 13px;
    border-radius: 999px;
    color: currentColor;
    opacity: 0.82;
    transition:
      opacity 0.2s var(--ease-brand),
      background-color 0.2s var(--ease-brand),
      color 0.2s var(--ease-brand);
  }
  .nav-link:hover {
    opacity: 1;
  }

  /* Телефон в шапке — наследует цвет шапки (белый над hero, тёмный при скролле) */
  .header-phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 999px;
    font-size: var(--text-sm);
    font-weight: 600;
    color: currentColor;
    opacity: 0.9;
    white-space: nowrap;
    transition:
      opacity 0.2s var(--ease-brand),
      background-color 0.2s var(--ease-brand),
      color 0.2s var(--ease-brand);
  }
  .header-phone:hover {
    opacity: 1;
    background-color: rgba(255, 255, 255, 0.14);
  }

  /* При скролле — подложка «лён», блюр, тёмный текст */
  #site-header.is-scrolled {
    background-color: color-mix(in srgb, var(--color-linen) 82%, transparent);
    -webkit-backdrop-filter: blur(14px) saturate(1.3);
    backdrop-filter: blur(14px) saturate(1.3);
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-line);
  }
  #site-header.is-scrolled .header-bar {
    height: 4rem;
  }
  #site-header.is-scrolled .nav-link {
    color: var(--color-muted);
    opacity: 1;
  }
  #site-header.is-scrolled .nav-link:hover {
    color: var(--color-pine-700);
    background-color: var(--color-pine-50);
  }
  #site-header.is-scrolled .header-phone:hover {
    color: var(--color-pine-700);
    background-color: var(--color-pine-50);
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const sync = () => header?.classList.toggle('is-scrolled', window.scrollY > 8);
  sync();
  window.addEventListener('scroll', sync, { passive: true });
</script>
