---
import { Icon } from 'astro-icon/components';
import LeadFields from './LeadFields.astro';
---

<!-- Короткий попап: открывается с карточек («Хочу сюда» / «Оставить заявку» в карточке).
     Подставляет конкретный санаторий. -->
<dialog id="lead-modal-short" class="modal modal--form" aria-label="Быстрая заявка">
  <div class="modal__inner p-7 sm:p-8">
    <button type="button" class="modal__close" data-lead-close aria-label="Закрыть">
      <Icon name="lucide:x" class="h-5 w-5" />
    </button>

    <p class="eyebrow">Оставить заявку</p>
    <h2 class="mt-3 font-display text-[1.6rem] font-semibold leading-tight">Быстрая заявка</h2>
    <p class="mt-2 hidden text-sm text-muted" data-lead-context></p>

    <div data-lead-root class="mt-6">
      <form data-lead-form class="grid gap-5" novalidate>
        <input type="hidden" name="sanatorium" data-lead-sanatorium />

        <label class="block">
          <span class="mb-1.5 block text-sm font-semibold text-ink-soft">Имя <span class="text-error">*</span></span>
          <input class="control" name="name" type="text" required autocomplete="name" placeholder="Как к вам обращаться" />
        </label>

        <label class="block">
          <span class="mb-1.5 block text-sm font-semibold text-ink-soft">Телефон <span class="text-error">*</span></span>
          <div class="input-wrap">
            <span class="prefix">+7</span>
            <input class="control with-prefix" name="phone" type="tel" required autocomplete="tel" inputmode="tel" placeholder="(900) 000-00-00" />
          </div>
        </label>

        <!-- honeypot (антиспам) -->
        <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

        <label class="check">
          <input type="checkbox" name="consent" required />
          <span class="box">
            <Icon name="lucide:check" class="h-3.5 w-3.5" />
          </span>
          <span class="txt">Я согласен на обработку персональных данных в соответствии с <a href={`${import.meta.env.BASE_URL}privacy`}>политикой конфиденциальности</a>.</span>
        </label>

        <button type="submit" class="btn btn-primary btn-lg mt-1 w-full">Отправить заявку</button>
        <p class="text-center text-xs text-muted-2">Менеджер свяжется в ближайшее время. Имеются противопоказания — необходима консультация специалиста.</p>
      </form>

      <div data-lead-success class="hidden rounded-lg bg-success-bg p-8 text-center" style="border:1px solid #bce3cc;">
        <div class="mx-auto mb-4 grid h-14 w-14 place-items-center rounded-full bg-success text-white">
          <Icon name="lucide:check" class="h-7 w-7" />
        </div>
        <p class="font-display text-[1.4rem] font-semibold">Спасибо! Заявка принята</p>
        <p class="mt-2 text-sm text-ink-soft">Менеджер свяжется с вами в ближайшее время.</p>
        <button type="button" class="btn btn-primary btn-lg mt-6 w-full" data-lead-close>Продолжить поиск</button>
      </div>
    </div>
  </div>
</dialog>

<!-- Полный попап: открывается кнопкой «Оставить заявку» в шапке. Та же форма, что внизу страницы. -->
<dialog id="lead-modal-full" class="modal modal--form-wide" aria-label="Оставить заявку">
  <div class="modal__inner p-7 sm:p-8">
    <button type="button" class="modal__close" data-lead-close aria-label="Закрыть">
      <Icon name="lucide:x" class="h-5 w-5" />
    </button>

    <p class="eyebrow">Оставить заявку</p>
    <h2 class="mt-3 font-display text-[1.7rem] font-semibold leading-tight">Подберём санаторий под вас</h2>
    <p class="mt-2 text-sm text-muted">Заполните форму — менеджер свяжется в ближайшее время.</p>

    <LeadFields class="mt-6" closeButton />
  </div>
</dialog>

<script>
  const shortDialog = document.getElementById('lead-modal-short') as HTMLDialogElement;
  const fullDialog = document.getElementById('lead-modal-full') as HTMLDialogElement;
  const dialogs = [shortDialog, fullDialog].filter(Boolean) as HTMLDialogElement[];

  // Привести попап к исходному виду: показать форму, спрятать «спасибо», очистить поля.
  function resetDialog(dialog: HTMLDialogElement) {
    const root = dialog.querySelector('[data-lead-root]');
    if (!root) return;
    const form = root.querySelector<HTMLFormElement>('[data-lead-form]');
    form?.reset();
    form?.classList.remove('hidden');
    root.querySelector('[data-lead-success]')?.classList.add('hidden');
  }

  function openDialog(dialog: HTMLDialogElement, sanatorium?: string) {
    resetDialog(dialog);

    const ctx = dialog.querySelector('[data-lead-context]') as HTMLElement | null;
    const hidden = dialog.querySelector('[data-lead-sanatorium]') as HTMLInputElement | null;
    const select = dialog.querySelector('[data-lead-sanatorium-select]') as HTMLSelectElement | null;

    if (sanatorium) {
      if (hidden) hidden.value = sanatorium;
      if (select) select.value = sanatorium;
      if (ctx) { ctx.textContent = `Санаторий: ${sanatorium}`; ctx.classList.remove('hidden'); }
    } else {
      if (hidden) hidden.value = '';
      if (ctx) { ctx.textContent = ''; ctx.classList.add('hidden'); }
    }

    document.body.classList.add('modal-open');
    dialog.showModal();
    const inner = dialog.querySelector('.modal__inner') as HTMLElement | null;
    if (inner) inner.scrollTop = 0;
  }

  function openLead(variant?: string, sanatorium?: string) {
    const wantFull = variant === 'full' || (!variant && !sanatorium);
    openDialog(wantFull ? fullDialog : shortDialog, sanatorium);
  }

  // Закрытие диалогов: крестик / фон / Esc. Блокировку прокрутки снимаем,
  // только если под текущим попапом не осталось открытого (стэк попапов).
  for (const dialog of dialogs) {
    dialog.addEventListener('close', () => {
      if (!document.querySelector('dialog.modal[open]')) {
        document.body.classList.remove('modal-open');
      }
      resetDialog(dialog);
    });
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
    dialog.querySelectorAll('[data-lead-close]').forEach((b) =>
      b.addEventListener('click', () => dialog.close()),
    );
  }

  // Единая точка входа: событие lead:open (его шлют карточки и делегированные клики).
  document.addEventListener('lead:open', (e) => {
    const detail = (e as CustomEvent).detail || {};
    openLead(detail.variant, detail.sanatorium);
  });

  // Любой элемент с data-lead-open открывает попап (шапка, футер и т.п.).
  document.addEventListener('click', (e) => {
    const trigger = (e.target as HTMLElement).closest?.('[data-lead-open]') as HTMLElement | null;
    if (!trigger) return;
    e.preventDefault();
    document.dispatchEvent(new CustomEvent('lead:open', {
      detail: { variant: trigger.dataset.leadVariant, sanatorium: trigger.dataset.leadSanatorium },
    }));
  });

  // Отправка ЛЮБОЙ формы заявки (нижняя + оба попапа) — общий обработчик.
  document.addEventListener('submit', (e) => {
    const form = (e.target as HTMLElement).closest?.('[data-lead-form]') as HTMLFormElement | null;
    if (!form) return;
    e.preventDefault();
    if (!form.reportValidity()) return;
    const hp = form.querySelector('input[name="company"]') as HTMLInputElement | null;
    if (hp && hp.value) return; // спам-бот заполнил honeypot
    // TODO (Этап 7): отправка заявки в Telegram и/или на email через прослойку.
    const root = form.closest('[data-lead-root]');
    const success = root?.querySelector('[data-lead-success]') as HTMLElement | null;
    form.classList.add('hidden');
    success?.classList.remove('hidden');
    const inner = form.closest('.modal__inner') as HTMLElement | null;
    if (inner) inner.scrollTop = 0;
    else success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
</script>
