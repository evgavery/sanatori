---
import { Icon } from 'astro-icon/components';
const base = import.meta.env.BASE_URL;
// Cache-bust для hero-видео и постера: меняем при каждой замене файлов,
// иначе у вернувшихся пользователей mp4 сидит в браузерном кеше до 45 дней.
const heroVer = '4';
---

<section id="top" class="relative flex h-[100svh] flex-col overflow-hidden">
  <!-- Фоновое видео + затемнение -->
  <!-- Чтобы стык лупа не «дёргался»: за ~0.5с до конца видео плавно гаснет
       в тёмный фон контейнера (bg ниже) и так же плавно проявляется после
       рестарта. Сглаживанием управляет короткий скрипт ниже; если JS не
       выполнится — остаётся нативный loop (как было). -->
  <div class="absolute inset-0 -z-10 bg-[#14271e]" data-hero-media>
    <video
      class="hero-video absolute inset-0 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={`${base}video/hero-poster.jpg?v=${heroVer}`}
    >
      <source src={`${base}video/hero.mp4?v=${heroVer}`} type="video/mp4" />
    </video>
    <!-- Затемнение поверх видео (из дизайн-системы): прозрачный → тёмный лес -->
    <div class="hero-overlay absolute inset-0"></div>
  </div>

  <!-- Контент (шапка вынесена в фиксированный Header) -->
  <div class="container-px flex flex-1 items-center">
    <div class="max-w-2xl py-24 text-ondark lg:max-w-5xl">
      <p class="eyebrow eyebrow-aqua mb-5">Оздоровление в лучших здравницах России</p>
      <h1 class="font-display text-[clamp(2.5rem,1.7rem+3vw,3.75rem)] font-semibold leading-[1.08]">
        Санатории <em class="font-medium italic text-sand-300">Федерации Независимых Профсоюзов</em> России
      </h1>
      <p class="mt-6 max-w-xl text-lead font-semibold text-ondark lg:max-w-3xl">
        Откройте для себя уникальные природные лечебные факторы, современные медицинские программы
        и безупречный сервис в санаториях Кавказских Минеральных Вод, Балтийского побережья
        и города-курорта Сочи.
      </p>
      <div class="mt-9 flex flex-wrap gap-4">
        <a href="#catalog" class="btn btn-accent">Подобрать санаторий</a>
        <a href="#advantages" class="btn btn-ondark">
          Подробнее <Icon name="lucide:arrow-down" class="h-[18px] w-[18px]" />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-video {
    /* длительность совпадает с FADE в скрипте */
    transition: opacity 0.5s linear;
  }
  .hero-overlay {
    background: linear-gradient(
      180deg,
      rgba(20, 39, 30, 0.45) 0%,
      rgba(20, 39, 30, 0.6) 45%,
      rgba(20, 39, 30, 0.82) 100%
    );
  }
</style>

<script>
  // Сглаживаем стык нативного лупа: у конца гасим видео в тёмный фон,
  // после рестарта (currentTime ~0) проявляем обратно. Плавность — CSS-transition.
  const FADE = 0.5; // сек — должно совпадать с transition в .hero-video
  document
    .querySelectorAll<HTMLVideoElement>('[data-hero-media] video')
    .forEach((v) => {
      v.addEventListener('timeupdate', () => {
        if (!v.duration) return;
        v.style.opacity = v.duration - v.currentTime < FADE ? '0' : '1';
      });
    });
</script>
