---
import { Icon } from 'astro-icon/components';
const base = import.meta.env.BASE_URL;
---

<section id="top" class="relative flex h-[100svh] flex-col overflow-hidden">
  <!-- Фоновое видео + затемнение -->
  <div class="absolute inset-0 -z-10">
    <video
      class="h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={`${base}video/hero-poster.jpg`}
    >
      <source src={`${base}video/hero.mp4`} type="video/mp4" />
    </video>
    <!-- Затемнение поверх видео (из дизайн-системы): прозрачный → тёмный лес -->
    <div class="hero-overlay absolute inset-0"></div>
  </div>

  <!-- Контент (шапка вынесена в фиксированный Header) -->
  <div class="container-px flex flex-1 items-center">
    <div class="max-w-2xl py-24 text-ondark">
      <p class="eyebrow eyebrow-aqua mb-5">Оздоровление в лучших здравницах России</p>
      <h1 class="font-display text-[clamp(2.5rem,1.7rem+3vw,4.0625rem)] font-semibold leading-[1.08]">
        Санатории <em class="font-medium italic text-sand-300">Федерации Независимых Профсоюзов</em> России
      </h1>
      <p class="mt-6 max-w-xl text-lead text-ondark-soft">
        Откройте для себя уникальные природные лечебные факторы, современные медицинские программы
        и безупречный сервис в санаториях Кавказских Минеральных Вод, Балтийского побережья
        и города-курорта Сочи.
      </p>
      <div class="mt-9 flex flex-wrap gap-4">
        <a href="#catalog" class="btn btn-accent">Подобрать санаторий</a>
        <a href="#advantages" class="btn btn-ondark">
          Подробнее <Icon name="lucide:arrow-down" class="h-[18px] w-[18px]" />
        </a>
      </div>
      <p class="mt-10 text-xs text-ondark-soft/80">
        Имеются противопоказания. Необходима консультация специалиста.
      </p>
    </div>
  </div>
</section>

<style>
  .hero-overlay {
    background: linear-gradient(
      180deg,
      rgba(20, 39, 30, 0.45) 0%,
      rgba(20, 39, 30, 0.6) 45%,
      rgba(20, 39, 30, 0.82) 100%
    );
  }
</style>
