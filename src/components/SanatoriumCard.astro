---
import { Icon } from 'astro-icon/components';
import { facilityIcon, groupAmenities, photosFor, coverFor, type Sanatorium } from '../lib/content';

interface Props {
  s: Sanatorium;
  hidden?: boolean;
}
const { s, hidden = false } = Astro.props;

const dirs = s.directions.slice(0, 3);
const extraDirs = s.directions.length - dirs.length;
const footAmenities = s.amenities.slice(0, 3);
const extraAmenities = s.amenities.length - footAmenities.length;
const hasPrice = Boolean(s.price_from && s.price_from.trim());

const groups = groupAmenities(s.amenities);
const photos = photosFor(s);
const cover = coverFor(s);
const hasPhoto = photos.length > 0;
const multiPhoto = photos.length > 1;

// Русское склонение для подсказки «ещё N услуг»
function pluralRu(n: number, one: string, few: string, many: string): string {
  const d10 = n % 10;
  const d100 = n % 100;
  if (d10 === 1 && d100 !== 11) return one;
  if (d10 >= 2 && d10 <= 4 && (d100 < 10 || d100 >= 20)) return few;
  return many;
}
const moreLabel = `Ещё ${extraAmenities} ${pluralRu(extraAmenities, 'услуга', 'услуги', 'услуг')}`;
---

<article
  data-card
  data-region={s.region}
  data-id={s.id}
  hidden={hidden}
  class="scard group flex flex-col overflow-hidden rounded-lg border border-line bg-paper shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md"
>
  <button type="button" data-open class="flex flex-1 cursor-pointer flex-col text-left">
    <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-pine-400 to-aqua-500">
      <!-- Фолбэк под фото: показывается, если фото нет или не загрузилось -->
      <div class="absolute inset-0 grid select-none place-items-center text-white/70">
        <Icon name="lucide:mountain-snow" is:inline class="h-14 w-14" />
      </div>
      {hasPhoto && (
        <img
          src={cover}
          alt={s.name}
          loading="lazy"
          decoding="async"
          onerror="this.remove()"
          class="absolute inset-0 z-[1] h-full w-full object-cover transition duration-500 group-hover:scale-105"
        />
      )}
      <span class="absolute left-3.5 top-3.5 z-10 inline-flex select-none items-center gap-1.5 rounded-full bg-[rgba(20,39,30,0.55)] px-3 py-1.5 text-xs font-semibold text-ondark backdrop-blur-sm">
        <Icon name="lucide:map-pin" is:inline class="h-3.5 w-3.5" />{s.city}
      </span>
    </div>

    <div class="flex flex-1 flex-col gap-3 p-5">
      <h3 class="line-clamp-2 font-display text-[1.4rem] font-semibold leading-tight tracking-[-0.01em]">{s.name}</h3>
      <!-- Резервируем высоту под 3 строки описания — теги выстраиваются на одном уровне во всём ряду -->
      <p class="line-clamp-3 min-h-[4.5rem] text-sm text-muted">{s.description}</p>

      {s.directions.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {dirs.map((d) => <span class="dir-tag">{d}</span>)}
          {extraDirs > 0 && <span class="dir-tag dir-tag-more">+{extraDirs}</span>}
        </div>
      )}
    </div>
  </button>

  <div class="flex items-center justify-between gap-3 border-t border-line-soft px-5 py-3.5">
    <button type="button" data-open aria-label={`Открыть карточку: ${s.name}`} class="min-w-0 cursor-pointer">
      {hasPrice ? (
        <span class="text-sm text-muted">
          от <b class="font-display text-[1.2rem] font-semibold text-ink">{s.price_from}</b>
        </span>
      ) : (
        <span class="inline-flex items-center gap-1.5">
          {footAmenities.map((a) => (
            <span class="ic-mini" data-tip={a}>
              <Icon name={`lucide:${facilityIcon(a)}`} is:inline class="h-[17px] w-[17px]" />
            </span>
          ))}
          {extraAmenities > 0 && <span class="ic-mini ic-mini-more" data-tip={moreLabel}>+{extraAmenities}</span>}
        </span>
      )}
    </button>
    <button type="button" class="btn btn-primary btn-sm shrink-0" data-prefill={s.name}>Хочу сюда</button>
  </div>

  <!-- Содержимое попапа (рендерится на этапе сборки, клонируется в модалку по клику) -->
  <template data-modal-tpl>
    <div class="modal-card">
      {hasPhoto ? (
        <div class="modal-gallery relative aspect-[16/7] overflow-hidden bg-gradient-to-br from-pine-400 to-aqua-500" data-gallery>
          <div class="gallery-track flex h-full w-full" data-track>
            {photos.map((p, i) => (
              <button type="button" data-lightbox data-src={p} data-index={i} class="h-full w-full shrink-0 cursor-zoom-in">
                <img src={p} alt={`${s.name} — фото ${i + 1}`} loading="lazy" decoding="async" onerror="this.remove()" class="h-full w-full object-cover" />
              </button>
            ))}
          </div>
          {multiPhoto && (
            <Fragment>
              <button type="button" data-gallery-prev aria-label="Предыдущее фото" class="gallery-nav left-3">
                <Icon name="lucide:chevron-left" is:inline class="h-5 w-5" />
              </button>
              <button type="button" data-gallery-next aria-label="Следующее фото" class="gallery-nav right-3">
                <Icon name="lucide:chevron-right" is:inline class="h-5 w-5" />
              </button>
              <div class="gallery-dots" data-dots>
                {photos.map((_, i) => (
                  <button type="button" data-dot data-index={i} aria-label={`Фото ${i + 1}`} aria-current={i === 0 ? 'true' : 'false'} class="gallery-dot"></button>
                ))}
              </div>
            </Fragment>
          )}
        </div>
      ) : (
        <div class="grid aspect-[16/7] w-full place-items-center bg-gradient-to-br from-pine-400 to-aqua-500 text-white/65">
          <Icon name="lucide:mountain-snow" is:inline class="h-14 w-14" />
        </div>
      )}

      <div class="p-7">
        <span class="badge badge-aqua mb-3">
          <Icon name="lucide:map-pin" is:inline class="h-[15px] w-[15px]" />{s.city} · {s.region}
        </span>
        <h3 class="font-display text-[1.9rem] font-semibold leading-tight">{s.name}</h3>
        <p class="mt-2 flex items-start gap-1.5 text-sm text-muted">
          <Icon name="lucide:map-pin" is:inline class="mt-0.5 h-4 w-4 shrink-0" />{s.address}
        </p>

        <p class="mt-5 leading-relaxed text-ink-soft">{s.description}</p>

        {s.directions.length > 0 && (
          <div class="mt-6">
            <p class="text-xs font-bold uppercase tracking-[0.14em] text-muted-2">Лечебные профили</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {s.directions.map((d) => <span class="badge">{d}</span>)}
            </div>
          </div>
        )}

        <div class="mt-6">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-muted-2">Услуги и инфраструктура</p>
          <div class="mt-3 space-y-4">
            {groups.map((g) => (
              <div>
                <p class="text-xs font-semibold text-muted-2">{g.category}</p>
                <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-3">
                  {g.items.map((a) => (
                    <span class="inline-flex items-center gap-2 text-sm text-ink-soft">
                      <Icon name={`lucide:${facilityIcon(a)}`} is:inline class="h-4 w-4 shrink-0 text-pine-600" />{a}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="mt-8 border-t border-line pt-6">
          {hasPrice ? (
            <p class="mb-4 text-sm text-muted">
              от <b class="font-display text-[1.25rem] font-semibold text-ink">{s.price_from}</b> / сутки
            </p>
          ) : (
            <p class="mb-4 text-sm text-muted">Стоимость — уточняйте у менеджера</p>
          )}
          <button type="button" class="btn btn-primary btn-lg w-full" data-prefill={s.name}>
            {s.cta || 'Оставить заявку на этот санаторий'}
          </button>
        </div>
      </div>
    </div>
  </template>
</article>
