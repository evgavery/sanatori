---
import LeadFields from './LeadFields.astro';
---

<section id="lead" class="container-px py-20 sm:py-28">
  <div class="reveal mx-auto max-w-2xl panel p-8 sm:p-10">
    <div class="text-center">
      <p class="eyebrow justify-center">Оставить заявку</p>
      <h2 class="sec-title mt-4 text-h2">Подберём санаторий под вас</h2>
      <p class="sec-intro mt-4">Заполните форму — менеджер свяжется в ближайшее время.</p>
    </div>

    <LeadFields class="mt-8" />
  </div>
</section>
